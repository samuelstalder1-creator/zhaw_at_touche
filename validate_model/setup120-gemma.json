{
  "description": "Validation preset for the improved Gemma residual classifier. Reuses the saved embedding-LR bundle and feature state from models/setup120-gemma on the Gemma-generated test rows.",
  "scoring_backend": "embedding_residual_classifier",
  "model_dir": "models/setup120-gemma",
  "results_dir": "results/setup120-gemma",
  "input_files": [
    "data/generated/gemma4e4b/responses-test-with-neutral_gemma4e4b.jsonl"
  ],
  "calibration_input_files": [
    "data/generated/gemma4e4b/responses-validation-with-neutral_gemma4e4b.jsonl"
  ],
  "embedding_model_name": "sentence-transformers/all-mpnet-base-v2",
  "neutral_field": "gemma4_e4b",
  "threshold_metric": "macro_f1",
  "batch_size": 32,
  "max_length": 512,
  "device": "cuda"
}
